# ── API Keys ───────────────────────────────────────────────────────────────────
# Get from https://polygon.io/dashboard
POLYGON_API_KEY=your_polygon_api_key_here

# Rate limiting: free tier = 5 req/min, paid Starter ($29/mo) = set to 300
POLYGON_REQUESTS_PER_MINUTE=5
# Seconds to wait after a 429 before retrying (free tier resets every 60s)
POLYGON_RATE_LIMIT_BACKOFF=65

# Get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional: Telegram bot for stop-loss alerts
# Create a bot via @BotFather, then get your chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── QuestDB ────────────────────────────────────────────────────────────────────
QUESTDB_HOST=localhost
QUESTDB_PG_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

# ── Storage ────────────────────────────────────────────────────────────────────
SQLITE_PATH=data/meta.db
PARQUET_DIR=data/parquet
